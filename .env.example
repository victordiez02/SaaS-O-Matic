# Copiar a ".env" en la raíz solo si se quiere cambiar algún valor por defecto.
# docker-compose.yml funciona sin este fichero (usa los valores tras ":-").

# Puertos publicados en el host
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Ruta del SQLite dentro del contenedor (volumen ./data en el host)
DATABASE_PATH=/app/data/saas_o_matic.db
